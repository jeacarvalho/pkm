# Vault Configuration
VAULT_PATH=/path/to/obsidian/vault

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/vectors/chroma_db

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=bge-m3

# Gemini API Configuration (Sprint 07)
GEMINI_API_KEY=your_api_key_here

# Validation Configuration (Sprint 07 - Updated)
VALIDATION_PROVIDER=gemini
VALIDATION_MODEL=gemini-2.5-flash-lite
VALIDATION_TEMPERATURE=0.0
VALIDATION_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/logs/indexing.log

# Chunking
MAX_TOKENS=800
OVERLAP_TOKENS=100

# Reranking
RERANK_THRESHOLD=0.75

# Chapter Processing
CHAPTER_VALIDATION_TOP_K=5

# Output
OUTPUT_DIR=./data/processed
BOOKS_VAULT_PATH=/path/to/obsidian/vault/books
